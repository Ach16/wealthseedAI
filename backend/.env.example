# ==========================================
# Application Settings
# ==========================================
API_V1_STR=/api/v1
PROJECT_NAME="WealthSeed AI"

# ==========================================
# Database & Infrastructure
# ==========================================
# Connection string for the primary database (PostgreSQL/SQLite)
DATABASE_URL=sqlite:///./wealthseed.db
# Connection string for Redis (used for caching/queues)
REDIS_URL=redis://localhost:6379/0
# Path to store ChromaDB vector embeddings
CHROMA_DB_PATH=./chroma_db

# ==========================================
# Security & Authentication
# ==========================================
# Secret key for signing JWT tokens (generate a strong random string)
JWT_SECRET=your_jwt_secret_here

# ==========================================
# AI & LLM Providers
# ==========================================
# Primary LLM provider (e.g., openrouter, grok, openai)
DEFAULT_PROVIDER=openrouter
# Fallback LLM provider if the primary fails
FALLBACK_PROVIDER=grok

# OpenRouter configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Grok configuration (fallback)
GROK_API_KEY=your_grok_api_key_here

# HuggingFace API Token (for embeddings)
HF_TOKEN=your_huggingface_token_here

# ==========================================
# External Integrations
# ==========================================
# Google OAuth Credentials (for social login)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Resend Email API (for transactional emails)
RESEND_API_KEY=your_resend_api_key_here

# LangSmith Tracing (for LLM observability)
LANGSMITH_API_KEY=your_langsmith_api_key_here
